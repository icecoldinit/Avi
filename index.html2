<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Premier League — 26/27</title>
<style>
  :root{
    --bg:#efefec;
    --panel:#f8f8f6;
    --ink:#161616;
    --muted:#6f6f68;
    --line:#161616;
    --accent:#3a3a86;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background:var(--bg);
    color:var(--ink);
    font-family: ui-monospace, "SF Mono", "JetBrains Mono", "IBM Plex Mono", Menlo, Consolas, "Courier New", monospace;
    line-height:1.55;
    -webkit-font-smoothing:antialiased;
  }
  .wrap{max-width:920px;margin:0 auto;padding:40px 22px 90px;}

  /* ---- hero ---- */
  .hero p{margin:0 0 4px 0;font-size:16px;}
  .hero .lede{font-size:16px;color:var(--ink);}
  .tagline{margin-top:18px;font-size:13px;color:var(--muted);letter-spacing:.03em;}

  .x-embed{margin-bottom:20px;}
  .made-for{color:#1565c0;font-size:12.5px;margin-bottom:10px;font-weight:600;}
  #heroNextMatch{margin-top:18px;}

  .divider{
    border:none;
    border-top:2px solid var(--line);
    margin:30px 0;
    width:100%;
  }

  .section-label{font-size:13px;color:var(--muted);margin-bottom:2px;}
  .section-title{font-size:15px;font-weight:700;letter-spacing:.04em;margin:0 0 18px 0;text-transform:uppercase;}

  /* ---- nav ---- */
  nav{display:flex;gap:0;margin:26px 0 8px;flex-wrap:wrap;border-top:2px solid var(--line);border-bottom:2px solid var(--line);}
  nav button{
    font-family:inherit;font-size:13px;letter-spacing:.03em;
    background:none;border:none;color:var(--muted);
    padding:12px 16px;cursor:pointer;text-transform:uppercase;
    border-right:1px solid #ccccc4;
  }
  nav button:last-child{border-right:none;}
  nav button.active{color:var(--ink);font-weight:700;background:#e2e2dc;}
  nav button:hover{color:var(--ink);}

  section.view{display:none;}
  section.view.active{display:block;}

  /* ---- club grid ---- */
  .club-grid{
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(130px,1fr));
    gap:12px;
    margin-top:8px;
  }
  .club-card{
    background:var(--panel);
    border:1.5px solid var(--line);
    padding:14px 10px;
    text-align:center;
    cursor:pointer;
    transition:transform .12s ease, box-shadow .12s ease;
  }
  .club-card:hover{transform:translateY(-3px);box-shadow:3px 3px 0 var(--line);}
  .badge{
    width:52px;height:52px;border-radius:50%;
    margin:0 auto 10px;
    display:flex;align-items:center;justify-content:center;
    color:#fff;font-weight:700;font-size:15px;
    border:2px solid var(--line);
  }
  .club-name{font-size:12px;line-height:1.3;}
  .club-meta{font-size:10px;color:var(--muted);margin-top:3px;}

  /* ---- table ---- */
  table{width:100%;border-collapse:collapse;font-size:12.5px;}
  th,td{padding:8px 6px;text-align:center;border-bottom:1px solid #cfcfc8;}
  th{text-transform:uppercase;font-size:10.5px;color:var(--muted);font-weight:600;border-bottom:2px solid var(--line);}
  td.club-col,th.club-col{text-align:left;}
  tr:hover td{background:#e6e6e0;}
  .note{font-size:11.5px;color:var(--muted);margin-top:14px;}

  tr.zone-ucl td:first-child{border-left:4px solid #1565c0;}
  tr.zone-uel td:first-child{border-left:4px solid #f9a825;}
  tr.zone-uecl td:first-child{border-left:4px solid #2e7d32;}
  tr.zone-rel td:first-child{border-left:4px solid #c62828;}
  tr.zone-ucl td{background:#e8f0fa;}
  tr.zone-uel td{background:#fdf5e2;}
  tr.zone-uecl td{background:#eaf4ea;}
  tr.zone-rel td{background:#fbe9e9;}
  tr.zone-ucl:hover td{background:#d7e6f7;}
  tr.zone-uel:hover td{background:#f9ecc9;}
  tr.zone-uecl:hover td{background:#dcecdc;}
  tr.zone-rel:hover td{background:#f6d9d9;}

  @keyframes goldPulse{
    0%,100%{ box-shadow: inset 0 0 0 9999px rgba(255,215,0,.16); }
    50%{ box-shadow: inset 0 0 0 9999px rgba(255,215,0,.32); }
  }
  tr.first-place td{
    background:linear-gradient(90deg,#fff8e1,#ffecb3,#fff8e1);
    font-weight:700;
    position:relative;
  }
  tr.first-place td:first-child{border-left:4px solid #1565c0;}
  tr.first-place td{ animation:goldPulse 2.2s ease-in-out infinite; }
  tr.first-place:hover td{ background:linear-gradient(90deg,#fff3cd,#ffe08a,#fff3cd); }
  tr.first-place .trophy{margin-left:6px;display:inline-block;animation:trophyBob 1.6s ease-in-out infinite;}
  @keyframes trophyBob{
    0%,100%{ transform:translateY(0); }
    50%{ transform:translateY(-2px); }
  }

  .legend{display:flex;flex-wrap:wrap;gap:16px;margin-top:16px;font-size:11.5px;color:var(--muted);}
  .legend-item{display:flex;align-items:center;gap:6px;}
  .swatch{width:11px;height:11px;display:inline-block;border:1px solid var(--line);}
  .swatch.ucl{background:#1565c0;}
  .swatch.uel{background:#f9a825;}
  .swatch.uecl{background:#2e7d32;}
  .swatch.rel{background:#c62828;}
  .swatch.champ{background:linear-gradient(90deg,#ffd700,#ffb300);}

  /* ---- fixtures ---- */
  .fix-group h3{font-size:12.5px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);margin:26px 0 10px;}
  .fix-group h3:first-child{margin-top:0;}
  .match-row{
    display:flex;align-items:center;justify-content:space-between;
    padding:10px 4px;border-bottom:1px solid #d8d8d1;font-size:13px;gap:10px;
    cursor:pointer;
  }
  .match-row:hover{background:#e6e6e0;}
  .match-teams{display:flex;align-items:center;gap:10px;flex:1;}
  .match-teams span.vs{color:var(--muted);font-size:11px;}
  .match-time{color:var(--muted);font-size:11.5px;white-space:nowrap;text-align:right;line-height:1.5;}
  .tz-tag{font-size:9px;color:#9a9a92;border:1px solid #cfcfc8;border-radius:3px;padding:0 4px;margin-left:4px;text-transform:uppercase;}
  .mini-badge{width:22px;height:22px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;color:#fff;font-size:9px;font-weight:700;border:1px solid var(--line);flex-shrink:0;cursor:pointer;transition:transform .12s ease;}
  .mini-badge:hover{transform:scale(1.15);}

  /* ---- news ---- */
  .news-item{padding:16px 0;border-bottom:1px solid #d8d8d1;}
  .news-item:first-child{padding-top:0;}
  .news-tag{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;}
  .news-title{font-size:14.5px;font-weight:700;margin:4px 0 6px;}
  .news-body{font-size:13px;color:#333;}

  /* ---- modal ---- */
  .overlay{
    position:fixed;inset:0;background:rgba(20,20,18,.55);
    display:none;align-items:center;justify-content:center;padding:20px;z-index:50;
  }
  .overlay.active{display:flex;}
  .modal{
    background:var(--bg);border:2px solid var(--line);max-width:520px;width:100%;
    max-height:85vh;overflow-y:auto;padding:26px;position:relative;
  }
  .modal-close{
    position:absolute;top:14px;right:16px;background:none;border:none;font-size:18px;
    cursor:pointer;color:var(--ink);font-family:inherit;
  }
  .modal-head{display:flex;align-items:center;gap:14px;margin-bottom:18px;}
  .modal-badge{width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:17px;border:2px solid var(--line);flex-shrink:0;}
  .modal-head h2{font-size:17px;margin:0 0 2px;}
  .modal-head .sub{font-size:11.5px;color:var(--muted);}
  .modal-tabs{display:flex;border-top:1.5px solid var(--line);border-bottom:1.5px solid var(--line);margin-bottom:16px;}
  .modal-tabs button{flex:1;font-family:inherit;background:none;border:none;padding:9px;font-size:12px;text-transform:uppercase;letter-spacing:.03em;cursor:pointer;color:var(--muted);}
  .modal-tabs button.active{color:var(--ink);font-weight:700;background:#e2e2dc;}
  .modal-tabs button:first-child{border-right:1px solid var(--line);}
  .next-match{background:#e2e2dc;border:1.5px solid var(--line);padding:12px 14px;margin-bottom:16px;}
  .next-match-label{font-size:10px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);margin-bottom:8px;}
  .next-match-body{display:flex;align-items:center;gap:8px;font-size:13.5px;font-weight:700;flex-wrap:wrap;}
  .next-match-vs .vs-txt{font-weight:400;color:var(--muted);margin:0 4px;}
  .next-match-meta{font-size:11.5px;color:var(--muted);margin-top:6px;}
  .stadium-row{display:flex;justify-content:space-between;font-size:13px;padding:7px 0;border-bottom:1px solid #d8d8d1;}
  .stadium-row span:first-child{color:var(--muted);}
  .squad-group h4{font-size:11px;text-transform:uppercase;color:var(--muted);letter-spacing:.05em;margin:16px 0 6px;}
  .squad-group h4:first-child{margin-top:0;}
  .squad-list{list-style:none;margin:0;padding:0;font-size:13.5px;}
  .squad-list li{padding:5px 0;border-bottom:1px dotted #cfcfc8;}
  .modal-tab-panel{display:none;}
  .modal-tab-panel.active{display:block;}
  .disclaimer{font-size:10.5px;color:var(--muted);margin-top:16px;line-height:1.5;}

  .footer{font-size:11px;color:var(--muted);text-align:center;padding-bottom:6px;}
    .club-grid{grid-template-columns:repeat(auto-fill, minmax(96px,1fr));}
    .badge{width:44px;height:44px;font-size:13px;}
    table{font-size:11px;}
    th,td{padding:6px 3px;}
  }
</style>
</head>
<body>
<div class="wrap">

  <div class="hero">
    <div class="made-for">made for aloo aka (Avi)</div>
    <p>The Premier League.</p>
    <div class="tagline">Where legends are forged, histories are written, and every single second matters.</div>
    <div id="heroNextMatch"></div>
  </div>

  <hr class="divider">

  <nav id="nav">
    <button data-view="clubs" class="active">Clubs</button>
    <button data-view="table">Table</button>
    <button data-view="fixtures">Fixtures</button>
    <button data-view="news">News</button>
  </nav>

  <div style="margin-top:26px;">

    <section id="view-clubs" class="view active">
            <div class="section-title">Clubs — 2026/27 Season</div>
      <div class="club-grid" id="clubGrid"></div>
      <div class="note">Tap a club to see its stadium and squad. Promoted from the Championship: Coventry City, Ipswich Town, Hull City.</div>
    </section>

    <section id="view-table" class="view">
            <div class="section-title">League Table</div>
      <table>
        <thead>
          <tr>
            <th>#</th><th class="club-col">Club</th><th>P</th><th>W</th><th>D</th><th>L</th><th>GF</th><th>GA</th><th>GD</th><th>Pts</th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
      <div class="legend">
        <div class="legend-item"><span class="swatch champ"></span>Champions (1st)</div>
        <div class="legend-item"><span class="swatch ucl"></span>Champions League (1–4)</div>
        <div class="legend-item"><span class="swatch uel"></span>Europa League (5)</div>
        <div class="legend-item"><span class="swatch uecl"></span>Conference League (6)</div>
        <div class="legend-item"><span class="swatch rel"></span>Relegation (18–20)</div>
      </div>
      <div class="note">The 2026/27 season kicks off Friday 21 August 2026 — every club starts level on zero. Table shown in alphabetical order pre-season; zone shading follows standard qualification positions, not current form.</div>
    </section>

    <section id="view-fixtures" class="view">
            <div class="section-title">Match Schedule</div>
      <div id="fixturesWrap"></div>
      <div class="note">Confirmed opening-weekend, Boxing Day and final-day fixtures for 2026/27. Times are shown in both UK local time and IST (India Standard Time) and are subject to change for broadcast.</div>
    </section>

    <section id="view-news" class="view">
            <div class="section-title">News</div>
      <div class="x-embed">
        <blockquote class="twitter-tweet" data-media-max-width="560"><p lang="en" dir="ltr">𝑰𝒕’𝒔 𝒈𝒆𝒕𝒕𝒊𝒏𝒈 𝒄𝒐𝒍𝒅 𝒉𝒆𝒓𝒆… 🥶❄️ <a href="https://t.co/We6YvGjFV1">pic.twitter.com/We6YvGjFV1</a></p>&mdash; ياسر (@u26s_) <a href="https://x.com/u26s_/status/2079197772968849745?ref_src=twsrc%5Etfw">July 20, 2026</a></blockquote>
      </div>
      <div id="newsWrap"></div>
    </section>

  </div>

  <hr class="divider">
  <div class="footer">© 2026 IceColdInit. All rights reserved.</div>
</div>

<div class="overlay" id="overlay">
  <div class="modal">
    <button class="modal-close" id="modalClose">✕ close</button>
    <div class="modal-head">
      <div class="modal-badge" id="modalBadge"></div>
      <div>
        <h2 id="modalName"></h2>
        <div class="sub" id="modalSub"></div>
      </div>
    </div>
    <div class="modal-tabs">
      <button data-tab="stadium" class="active">Overview</button>
      <button data-tab="squad">Squad</button>
    </div>
    <div class="modal-tab-panel active" id="panel-stadium"></div>
    <div class="modal-tab-panel" id="panel-squad"></div>
    <div class="disclaimer">Squad and management details reflect the most recently known information and may not capture every summer 2026 transfer.</div>
  </div>
</div>

<script>
const CLUBS = [
  {code:"ARS", name:"Arsenal", color:"#EF0107", city:"London", stadium:"Emirates Stadium", capacity:"60,704", manager:"Mikel Arteta",
    squad:{GK:["David Raya","Kepa Arrizabalaga"],DF:["William Saliba","Gabriel Magalhães","Jurriën Timber","Riccardo Calafiori","Myles Lewis-Skelly"],MF:["Declan Rice","Martín Ødegaard","Mikel Merino"],FW:["Bukayo Saka","Gabriel Martinelli","Kai Havertz","Viktor Gyökeres","Leandro Trossard"]}},
  {code:"AVL", name:"Aston Villa", color:"#670E36", city:"Birmingham", stadium:"Villa Park", capacity:"42,918", manager:"Unai Emery",
    squad:{GK:["Emiliano Martínez"],DF:["Ezri Konsa","Pau Torres","Lucas Digne","Matty Cash"],MF:["Youri Tielemans","John McGinn","Morgan Rogers","Amadou Onana"],FW:["Ollie Watkins","Marcus Rashford"]}},
  {code:"BOU", name:"Bournemouth", color:"#DA291C", city:"Bournemouth", stadium:"Vitality Stadium", capacity:"11,364", manager:"Marco Rose",
    squad:{GK:["Djordje Petrović"],DF:["Marcos Senesi","Adam Smith","Bafodé Diakité"],MF:["Alex Scott","Ryan Christie","Justin Kluivert"],FW:["Antoine Semenyo","Evanilson"]}},
  {code:"BRE", name:"Brentford", color:"#E30613", city:"London", stadium:"Gtech Community Stadium", capacity:"17,250", manager:"Keith Andrews",
    squad:{GK:["Mark Flekken"],DF:["Nathan Collins","Kristoffer Ajer","Rico Henry"],MF:["Mikkel Damsgaard","Vitaly Janelt"],FW:["Yoane Wissa","Igor Thiago"]}},
  {code:"BHA", name:"Brighton & Hove Albion", color:"#0057B8", city:"Brighton", stadium:"American Express Stadium", capacity:"31,800", manager:"Fabian Hürzeler",
    squad:{GK:["Bart Verbruggen"],DF:["Lewis Dunk","Jan Paul van Hecke","Pervis Estupiñán"],MF:["Carlos Baleba","Mats Wieffer"],FW:["Kaoru Mitoma","Georginio Rutter","Danny Welbeck"]}},
  {code:"CHE", name:"Chelsea", color:"#034694", city:"London", stadium:"Stamford Bridge", capacity:"40,343", manager:"Xabi Alonso",
    squad:{GK:["Robert Sánchez"],DF:["Levi Colwill","Wesley Fofana","Reece James","Marc Cucurella"],MF:["Moisés Caicedo","Enzo Fernández"],FW:["Cole Palmer","Nicolas Jackson","Pedro Neto"]}},
  {code:"COV", name:"Coventry City", color:"#78D0F2", city:"Coventry", stadium:"Coventry Building Society Arena", capacity:"32,609", manager:"Frank Lampard",
    squad:{GK:["Ben Wilson"],DF:["Luis Binks","Jake Bidwell"],MF:["Jack Rudoni","Josh Eccles"],FW:["Ellis Simms","Haji Wright"]}},
  {code:"CRY", name:"Crystal Palace", color:"#1B458F", city:"London", stadium:"Selhurst Park", capacity:"25,486", manager:"Oliver Glasner",
    squad:{GK:["Dean Henderson"],DF:["Marc Guéhi","Chris Richards","Tyrick Mitchell"],MF:["Adam Wharton","Will Hughes"],FW:["Eberechi Eze","Jean-Philippe Mateta"]}},
  {code:"EVE", name:"Everton", color:"#003399", city:"Liverpool", stadium:"Hill Dickinson Stadium", capacity:"52,769", manager:"David Moyes",
    squad:{GK:["Jordan Pickford"],DF:["Jarrad Branthwaite","James Tarkowski","Vitaliy Mykolenko"],MF:["Idrissa Gueye","James Garner"],FW:["Iliman Ndiaye","Dwight McNeil","Beto"]}},
  {code:"FUL", name:"Fulham", color:"#000000", city:"London", stadium:"Craven Cottage", capacity:"29,600", manager:"Marco Silva",
    squad:{GK:["Bernd Leno"],DF:["Calvin Bassey","Joachim Andersen","Antonee Robinson"],MF:["Sander Berge","Emile Smith Rowe"],FW:["Rodrigo Muniz","Alex Iwobi"]}},
  {code:"HUL", name:"Hull City", color:"#F18A00", city:"Hull", stadium:"MKM Stadium", capacity:"25,586", manager:"—",
    squad:{GK:["Ivor Pandur"],DF:["Jacob Greaves","Alfie Jones"],MF:["Regan Slater","Ryan Giles"],FW:["Ozan Tufan","Fabio Carvalho"]}},
  {code:"IPS", name:"Ipswich Town", color:"#0033A0", city:"Ipswich", stadium:"Portman Road", capacity:"30,014", manager:"—",
    squad:{GK:["Arijanet Muric"],DF:["Jacob Greaves","Axel Tuanzebe","Leif Davis"],MF:["Sammie Szmodics","Jack Taylor"],FW:["George Hirst","Omari Hutchinson"]}},
  {code:"LEE", name:"Leeds United", color:"#FFCD00", city:"Leeds", stadium:"Elland Road", capacity:"37,890", manager:"Daniel Farke",
    squad:{GK:["Karl Darlow"],DF:["Pascal Struijk","Ethan Ampadu","Junior Firpo"],MF:["Ilia Gruev","Brenden Aaronson"],FW:["Joel Piroe","Daniel James"]}},
  {code:"LIV", name:"Liverpool", color:"#C8102E", city:"Liverpool", stadium:"Anfield", capacity:"61,276", manager:"Andoni Iraola",
    squad:{GK:["Alisson"],DF:["Virgil van Dijk","Ibrahima Konaté","Andrew Robertson","Milos Kerkez"],MF:["Ryan Gravenberch","Alexis Mac Allister","Dominik Szoboszlai"],FW:["Mohamed Salah","Florian Wirtz","Cody Gakpo","Hugo Ekitike"]}},
  {code:"MCI", name:"Manchester City", color:"#6CABDD", city:"Manchester", stadium:"Etihad Stadium", capacity:"55,097", manager:"—",
    squad:{GK:["Ederson"],DF:["Rúben Dias","Joško Gvardiol","Nathan Aké"],MF:["Rodri","Mateo Kovačić"],FW:["Erling Haaland","Phil Foden","Savinho"]}},
  {code:"MUN", name:"Manchester United", color:"#DA291C", city:"Manchester", stadium:"Old Trafford", capacity:"74,197", manager:"Michael Carrick",
    squad:{GK:["Altay Bayındır"],DF:["Lisandro Martínez","Matthijs de Ligt","Noussair Mazraoui"],MF:["Bruno Fernandes","Casemiro","Bryan Mbeumo"],FW:["Rasmus Højlund","Mason Mount"]}},
  {code:"NEW", name:"Newcastle United", color:"#241F20", city:"Newcastle", stadium:"St James' Park", capacity:"52,305", manager:"Eddie Howe",
    squad:{GK:["Nick Pope"],DF:["Sven Botman","Fabian Schär","Kieran Trippier"],MF:["Bruno Guimarães","Sandro Tonali","Joelinton"],FW:["Alexander Isak","Anthony Gordon"]}},
  {code:"NFO", name:"Nottingham Forest", color:"#DD0000", city:"Nottingham", stadium:"City Ground", capacity:"30,445", manager:"—",
    squad:{GK:["Matz Sels"],DF:["Murillo","Ola Aina","Neco Williams"],MF:["Morgan Gibbs-White","Ibrahim Sangaré"],FW:["Chris Wood","Callum Hudson-Odoi"]}},
  {code:"SUN", name:"Sunderland", color:"#EB172F", city:"Sunderland", stadium:"Stadium of Light", capacity:"48,707", manager:"Régis Le Bris",
    squad:{GK:["Anthony Patterson"],DF:["Dan Ballard","Jenson Seelt","Trai Hume"],MF:["Chris Rigg","Dan Neil"],FW:["Wilson Isidor","Eliezer Mayenda"]}},
  {code:"TOT", name:"Tottenham Hotspur", color:"#132257", city:"London", stadium:"Tottenham Hotspur Stadium", capacity:"62,062", manager:"Thomas Frank",
    squad:{GK:["Guglielmo Vicario"],DF:["Cristian Romero","Micky van de Ven","Destiny Udogie"],MF:["Rodrigo Bentancur","Pape Matar Sarr","James Maddison"],FW:["Dominic Solanke","Brennan Johnson"]}}
];

// ---- render club grid ----
const grid = document.getElementById('clubGrid');
CLUBS.forEach(c=>{
  const card=document.createElement('div');
  card.className='club-card';
  card.innerHTML=`<div class="badge" style="background:${c.color}">${c.code}</div>
    <div class="club-name">${c.name}</div>
    <div class="club-meta">${c.city}</div>`;
  card.addEventListener('click',()=>openModal(c));
  grid.appendChild(card);
});

// ---- render table (alphabetical, preseason all zero) ----
const tableBody=document.getElementById('tableBody');
[...CLUBS].sort((a,b)=>a.name.localeCompare(b.name)).forEach((c,i)=>{
  const pos=i+1;
  const tr=document.createElement('tr');
  tr.style.cursor='pointer';
  if(pos===1) tr.classList.add('first-place');
  else if(pos<=4) tr.classList.add('zone-ucl');
  else if(pos===5) tr.classList.add('zone-uel');
  else if(pos===6) tr.classList.add('zone-uecl');
  else if(pos>=18) tr.classList.add('zone-rel');
  const trophy = pos===1 ? '<span class="trophy">🏆</span>' : '';
  tr.innerHTML=`<td>${pos}</td><td class="club-col">${c.name}${trophy}</td><td>0</td><td>0</td><td>0</td><td>0</td><td>0</td><td>0</td><td>0</td><td>0</td>`;
  tr.addEventListener('click',()=>openModal(c));
  tableBody.appendChild(tr);
});

// ---- fixtures data ----
function findClub(name){
  return CLUBS.find(c=> name.includes(c.name) || c.name.includes(name) );
}
function miniBadge(name){
  const c = findClub(name);
  if(!c) return `<span class="mini-badge" style="background:#888">${name.slice(0,3).toUpperCase()}</span>`;
  return `<span class="mini-badge" style="background:${c.color}" onclick="event.stopPropagation(); openClubByName('${c.name.replace(/'/g,"\\'")}')">${c.code}</span>`;
}
function openClubByName(name){
  const c = CLUBS.find(cl=>cl.name===name);
  if(c) openModal(c);
}
function matchRow(home,away,time,uk,ist){
  const idx = FIXTURES_FLAT.push({home,away,time,uk,ist}) - 1;
  return `<div class="match-row" onclick="openMatchModal(${idx})">
    <div class="match-teams">${miniBadge(home)} ${home} <span class="vs">vs</span> ${away} ${miniBadge(away)}</div>
    <div class="match-time">
      <div>${time} <span class="tz-tag">UK</span></div>
      <div>${ist} <span class="tz-tag">IST</span></div>
    </div>
  </div>`;
}
const FIXTURES_FLAT=[];

const FIXTURES = [
  {title:"Opening Weekend — Matchweek 1", matches:[
    ["Arsenal","Coventry City","Fri 21 Aug, 8:00pm","Sky Sports","Sat 22 Aug, 12:30am"],
    ["Hull City","Manchester United","Sat 22 Aug, 12:30pm","TNT Sports","Sat 22 Aug, 5:00pm"],
    ["Everton","Crystal Palace","Sat 22 Aug, 3:00pm","TNT Sports","Sat 22 Aug, 7:30pm"],
    ["Ipswich Town","Sunderland","Sat 22 Aug, 3:00pm","TNT Sports","Sat 22 Aug, 7:30pm"],
    ["Nottingham Forest","Leeds United","Sat 22 Aug, 3:00pm","TNT Sports","Sat 22 Aug, 7:30pm"],
    ["Brentford","Tottenham Hotspur","Sat 22 Aug, 5:30pm","Sky Sports","Sat 22 Aug, 10:00pm"],
    ["Brighton & Hove Albion","Aston Villa","Sun 23 Aug, 2:00pm","Sky Sports","Sun 23 Aug, 6:30pm"],
    ["Manchester City","Bournemouth","Sun 23 Aug, 2:00pm","Sky Sports","Sun 23 Aug, 6:30pm"],
    ["Newcastle United","Liverpool","Sun 23 Aug, 4:30pm","Sky Sports","Sun 23 Aug, 9:00pm"],
    ["Fulham","Chelsea","Mon 24 Aug, 8:00pm","Sky Sports","Tue 25 Aug, 12:30am"]
  ]},
  {title:"Boxing Day Fixtures — 26 December 2026", matches:[
    ["Aston Villa","Leeds United","TBC","TBC","TBC"],
    ["Coventry City","Chelsea","TBC","TBC","TBC"],
    ["Crystal Palace","Arsenal","TBC","TBC","TBC"],
    ["Everton","Sunderland","TBC","TBC","TBC"],
    ["Fulham","Brighton & Hove Albion","TBC","TBC","TBC"],
    ["Hull City","Liverpool","TBC","TBC","TBC"],
    ["Ipswich Town","Brentford","TBC","TBC","TBC"],
    ["Manchester United","Nottingham Forest","TBC","TBC","TBC"],
    ["Newcastle United","Manchester City","TBC","TBC","TBC"],
    ["Tottenham Hotspur","Bournemouth","TBC","TBC","TBC"]
  ]},
  {title:"Final Day — Matchweek 38, 30 May 2027", matches:[
    ["Arsenal","Brighton & Hove Albion","4:00pm","TBC","8:30pm"],
    ["Aston Villa","Tottenham Hotspur","4:00pm","TBC","8:30pm"],
    ["Chelsea","Brentford","4:00pm","TBC","8:30pm"],
    ["Coventry City","Nottingham Forest","4:00pm","TBC","8:30pm"],
    ["Crystal Palace","Leeds United","4:00pm","TBC","8:30pm"],
    ["Hull City","Newcastle United","4:00pm","TBC","8:30pm"],
    ["Ipswich Town","Everton","4:00pm","TBC","8:30pm"],
    ["Liverpool","Bournemouth","4:00pm","TBC","8:30pm"],
    ["Manchester United","Fulham","4:00pm","TBC","8:30pm"],
    ["Sunderland","Manchester City","4:00pm","TBC","8:30pm"]
  ]}
];

const fixturesWrap=document.getElementById('fixturesWrap');
FIXTURES.forEach(group=>{
  const div=document.createElement('div');
  div.className='fix-group';
  div.innerHTML=`<h3>${group.title}</h3>` + group.matches.map(m=>matchRow(m[0],m[1],m[2],m[3],m[4])).join('');
  fixturesWrap.appendChild(div);
});

// ---- hero: next upcoming match (season opener) ----
(function renderHeroNextMatch(){
  const [home,away,time,uk,ist] = FIXTURES[0].matches[0];
  const homeClub = findClub(home);
  const stadium = homeClub ? homeClub.stadium : home;
  document.getElementById('heroNextMatch').innerHTML = `
    <div class="next-match">
      <div class="next-match-label">Next Match — Season Opener</div>
      <div class="next-match-body">
        ${miniBadge(home)} <span class="next-match-vs">${home} <span class="vs-txt">vs</span> ${away}</span> ${miniBadge(away)}
      </div>
      <div class="next-match-meta">${stadium}</div>
      <div class="next-match-meta">${time} <span class="tz-tag">UK</span> &nbsp;·&nbsp; ${ist} <span class="tz-tag">IST</span></div>
    </div>`;
})();

const INDIA_BROADCAST = "JioHotstar (streaming) & Star Sports Select HD1 (TV)";

function openMatchModal(idx){
  const m = FIXTURES_FLAT[idx];
  const homeClub = findClub(m.home);
  const stadium = homeClub ? homeClub.stadium : m.home;
  modalBadge.style.background = homeClub ? homeClub.color : "#888";
  modalBadge.textContent = homeClub ? homeClub.code : "";
  modalName.textContent = `${m.home} vs ${m.away}`;
  modalSub.textContent = stadium;

  panelStadium.innerHTML = `
    <div class="stadium-row"><span>Kick-off — UK</span><span>${m.time}</span></div>
    <div class="stadium-row"><span>Kick-off — IST</span><span>${m.ist}</span></div>
    <div class="stadium-row"><span>Venue</span><span>${stadium}</span></div>
    <div class="stadium-row"><span>UK Broadcast</span><span>${m.uk}</span></div>
    <div class="stadium-row"><span>India Broadcast</span><span>${m.uk==="TBC" ? "TBC" : INDIA_BROADCAST}</span></div>
  `;
  panelSquad.innerHTML = `<div class="note" style="margin-top:0;">Squad details are shown on each club's own card — open a club from the Clubs tab to view its full squad.</div>`;

  document.querySelectorAll('.modal-tabs button').forEach(b=>b.classList.remove('active'));
  document.querySelector('.modal-tabs button[data-tab="stadium"]').classList.add('active');
  document.querySelector('.modal-tabs button[data-tab="stadium"]').textContent="Match Info";
  document.querySelector('.modal-tabs button[data-tab="squad"]').style.display='none';
  panelStadium.classList.add('active');
  panelSquad.classList.remove('active');

  overlay.classList.add('active');
}

// ---- news ----
const NEWS = [
  {tag:"Season Preview", title:"Arsenal open title defence against Coventry", body:"Mikel Arteta's side begin the defence of their first league title in 22 years at home to newly promoted Coventry City on the opening Friday night of the season."},
  {tag:"Managers", title:"Fresh faces in the dugout", body:"Xabi Alonso takes charge at Stamford Bridge, Michael Carrick leads Manchester United into a full season, and Andoni Iraola swaps Bournemouth for Anfield as Liverpool's new head coach."},
  {tag:"Promoted Clubs", title:"Coventry, Ipswich and Hull return to the top flight", body:"Frank Lampard's Coventry City, Ipswich Town and Hull City replace relegated Wolves, Burnley and West Ham, taking the division back to 20 clubs for 2026/27."},
  {tag:"Fixtures", title:"Boxing Day schedule confirmed", body:"The traditional 26 December programme returns with a full round of ten fixtures, headlined by Crystal Palace hosting champions Arsenal."},
  {tag:"Calendar", title:"Season to finish with Championship Sunday", body:"All ten final-day fixtures on 30 May 2027 will kick off simultaneously, as is now standard for the last round of the Premier League season."}
];
const newsWrap=document.getElementById('newsWrap');
NEWS.forEach(n=>{
  const div=document.createElement('div');
  div.className='news-item';
  div.innerHTML=`<div class="news-tag">${n.tag}</div><div class="news-title">${n.title}</div><div class="news-body">${n.body}</div>`;
  newsWrap.appendChild(div);
});

// ---- nav switching ----
document.querySelectorAll('#nav button').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('#nav button').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('section.view').forEach(s=>s.classList.remove('active'));
    document.getElementById('view-'+btn.dataset.view).classList.add('active');
  });
});

// ---- modal ----
const overlay=document.getElementById('overlay');
const modalBadge=document.getElementById('modalBadge');
const modalName=document.getElementById('modalName');
const modalSub=document.getElementById('modalSub');
const panelStadium=document.getElementById('panel-stadium');
const panelSquad=document.getElementById('panel-squad');

function findNextMatch(c){
  const mw1 = FIXTURES[0].matches; // opening weekend — every club appears exactly once
  for(const [home,away,time,uk,ist] of mw1){
    if(home===c.name) return {opponent:away, stadium:c.stadium, time, ist};
    if(away===c.name){
      const homeClub=findClub(home);
      return {opponent:home, stadium: homeClub ? homeClub.stadium : home, time, ist};
    }
  }
  return null;
}

function openModal(c){
  document.querySelector('.modal-tabs button[data-tab="stadium"]').textContent="Overview";
  document.querySelector('.modal-tabs button[data-tab="squad"]').style.display='';
  modalBadge.style.background=c.color;
  modalBadge.textContent=c.code;
  modalName.textContent=c.name;
  modalSub.textContent=c.city+" · Manager: "+c.manager;

  const next=findNextMatch(c);
  const nextHtml = next ? `
    <div class="next-match">
      <div class="next-match-label">Next Match — Matchweek 1</div>
      <div class="next-match-body">
        <span class="mini-badge" style="background:${c.color}">${c.code}</span>
        <span class="next-match-vs">${c.name} <span class="vs-txt">vs</span> ${next.opponent}</span>
        ${miniBadge(next.opponent)}
      </div>
      <div class="next-match-meta">${next.stadium}</div>
      <div class="next-match-meta">${next.time} <span class="tz-tag">UK</span> &nbsp;·&nbsp; ${next.ist} <span class="tz-tag">IST</span></div>
    </div>` : '';

  panelStadium.innerHTML=`
    ${nextHtml}
  `;

  const groups=[["Goalkeepers","GK"],["Defenders","DF"],["Midfielders","MF"],["Forwards","FW"]];
  panelSquad.innerHTML = groups.map(([label,key])=>{
    const players=c.squad[key]||[];
    if(!players.length) return '';
    return `<div class="squad-group"><h4>${label}</h4><ul class="squad-list">${players.map(p=>`<li>${p}</li>`).join('')}</ul></div>`;
  }).join('');

  document.querySelectorAll('.modal-tabs button').forEach(b=>b.classList.remove('active'));
  document.querySelector('.modal-tabs button[data-tab="stadium"]').classList.add('active');
  panelStadium.classList.add('active');
  panelSquad.classList.remove('active');

  overlay.classList.add('active');
}

document.querySelectorAll('.modal-tabs button').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.modal-tabs button').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    panelStadium.classList.toggle('active', btn.dataset.tab==='stadium');
    panelSquad.classList.toggle('active', btn.dataset.tab==='squad');
  });
});

document.getElementById('modalClose').addEventListener('click',()=>overlay.classList.remove('active'));
overlay.addEventListener('click',(e)=>{ if(e.target===overlay) overlay.classList.remove('active'); });
</script>
<script async src="https://platform.x.com/widgets.js" charset="utf-8"></script>
</body>
</html>
